# ─────────────────────────────────────────────────────────────────────────────
# Geo Embedder — переменные окружения
# Скопируйте этот файл в .env и заполните значения:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# API ключ OpenAI (нужен для 02_generate_queries.py и 03_mine_hard_negatives.py
OPENAI_API_KEY=sk-...
OPENAI_API_BASE="https://openrouter.ai/api/v1"

# ── Прокси (если API недоступен напрямую, например из РФ) ────────────────────
# SSH SOCKS5: ssh -D 0.0.0.0:1080 -N -f user@<vps-ip>
# Из Docker контейнера хост доступен через 172.17.0.1
# HTTPS_PROXY=socks5://172.17.0.1:1080
# Путь к дообученной модели внутри контейнера
# После обучения (04_train_embedder.py) модель сохраняется в ./models/finetuned-bge-m3-geo
# что соответствует /models/finetuned-bge-m3-geo внутри контейнера
MODEL_PATH=/models/finetuned-bge-m3-geo

# Пока модель не обучена — можно использовать базовую:
# MODEL_PATH=BAAI/bge-m3

# ── MLflow (04_train_embedder.py) ─────────────────────────────────────────────
# URI сервера MLflow. Если не задан — MLflow-логирование отключается автоматически.
MLFLOW_TRACKING_URI=http://172.17.0.1:5000

# Название эксперимента (создаётся автоматически если не существует)
MLFLOW_EXPERIMENT_NAME=geo-embedder

HF_TOKEN=hf_...